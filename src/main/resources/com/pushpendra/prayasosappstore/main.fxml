<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Priority?>

<VBox minHeight="400" prefHeight="720" prefWidth="1080"
      spacing="10" styleClass="main-container"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pushpendra.prayasosappstore.HelloController">

   <children>
      <HBox alignment="CENTER_LEFT" styleClass="header" minHeight="60" maxHeight="60">
         <Label text="prayasOS App Store" styleClass="header-title"/>
          <HBox HBox.hgrow="ALWAYS"/>
      </HBox>

      <ListView fx:id="appListView" VBox.vgrow="ALWAYS" styleClass="app-list"/>
   </children>
</VBox>
